APP_NAME=Arena Smart Money AI Trader API
APP_ENV=development
APP_VERSION=3.7.0-signal-alpha17
DEFAULT_TIMEZONE=UTC

# Comma-separated browser origins. Native Android does not need CORS.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL is required for production RC. DATABASE_PATH remains a local/test
# SQLite fallback only. Never commit a real connection string.
DATABASE_URL=
DATABASE_PATH=
DATABASE_POOL_MAX_SIZE=8
DATABASE_CONNECT_TIMEOUT_SECONDS=8
BACKUP_RETENTION_DAYS=14
USER_SECRET_MASTER_KEY=
USER_SECRET_KEY_VERSION=1
SESSION_TTL_HOURS=168

# Production request guards
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=20
RATE_LIMIT_HEAVY_PER_MINUTE=15
TRUST_PROXY_HEADERS=false
MAX_REQUEST_BODY_BYTES=2097152

# Demo user is development-only; keep false in production.
SEED_DEMO_USER=true

# Live market/news data
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=

# Provider-agnostic AI explanation layer. External AI is opt-in and can never
# override deterministic decisions. Keep keys in environment secrets only.
AI_PROVIDER=deterministic
AI_EXTERNAL_ENABLED=false
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4.1-mini
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=8
AI_CACHE_TTL_SECONDS=90
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_COOLDOWN_SECONDS=120

# Live execution safety switch (must remain false until separately approved)
ENABLE_LIVE_EXECUTION=false

# Binance Futures connector
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_BASE_URL=https://testnet.binancefuture.com

# Bybit connector
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api-testnet.bybit.com

# OANDA connector
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# MetaTrader 5 connector foundation
MT5_SERVER=
MT5_LOGIN=
MT5_PASSWORD=

# cTrader connector foundation
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_BASE_URL=https://demo.ctraderapi.com

# Firebase server push (optional real mode)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
PAPER_FEED_WORKER_ENABLED=true
PAPER_FEED_WORKER_SWEEP_SECONDS=2
PAPER_FEED_WORKER_BATCH_SIZE=20
PAPER_FEED_PROVIDER_TIMEOUT_SECONDS=8

PAPER_CHAOS_ENABLED=false
ENABLE_TESTNET_EXECUTION=false
SIGNAL_SHADOW_WORKER_ENABLED=false
SIGNAL_SHADOW_INTERVAL_SECONDS=900
SIGNAL_SHADOW_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,XAUUSD,EURUSD,GBPUSD,USDJPY,NAS100,US30
