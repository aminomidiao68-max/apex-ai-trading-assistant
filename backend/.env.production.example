APP_NAME=Apex AI Trading API
APP_ENV=production
APP_VERSION=3.7.0-signal-alpha26
DEFAULT_TIMEZONE=UTC
CORS_ALLOWED_ORIGINS=
DATABASE_URL=
DATABASE_PATH=
